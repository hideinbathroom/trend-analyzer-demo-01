# ===== LLM API 설정 =====
# 사용할 LLM 선택: "openai" / "anthropic" / "gemini"
LLM_PROVIDER=anthropic

# API 키 (선택한 provider에 맞는 키 입력)
# OpenAI: https://platform.openai.com/api-keys
# Anthropic: https://console.anthropic.com/settings/keys
# Gemini: https://aistudio.google.com/app/apikey
LLM_API_KEY=your_api_key_here

# ===== Threads API 설정 =====
# Meta Developer 포털에서 발급
THREADS_ACCESS_TOKEN=your_token_here
THREADS_USER_ID=your_user_id_here

# ===== Discord 웹훅 (뉴스 헤드라인 전송용) =====
# Discord 채널 설정 → 웹훅 생성 후 URL 입력
DISCORD_WEBHOOK_URL=

# ===== Telegram 봇 설정 =====
# @BotFather에서 봇 생성 후 토큰 입력
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== 네이버 검색 API 설정 =====
# https://developers.naver.com 에서 앱 등록 후 발급 (하루 25,000건 무료)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
